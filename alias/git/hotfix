#!/bin/bash

SCRIPT_CONTENT=$(cat <<'EOF'

    # colors
    GREEN="\033[0;32m";
    YELLOW="\033[1;33m";
    CYAN="\033[0;36m";
    RED="\033[0;31m"; NC="\033[0m";

    # globals
    SOURCE_BRANCH=""
    TARGET_BRANCHES_RAW=""
    FORCE_PUSH=false
    PICKY=false
    TARGET_BRANCHES=()
    SELECTED_COMMITS=()
    CREATED_BRANCHES=()
    PR_LINKS=()
    START_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

    show_help() {
        cat <<-MSG
Usage: git hotfix -f <source> -i <target1,target2>

Automates hotfix creation and PR generation.

    -f, --from <source>     (Required) The source branch containing commits.
    -i, --into <targets>    (Required) Comma-separated|Space list of target branches.
    --force                 Force pushes the branch creation over origin.
    -p, --picky             Allows the commits to be individually picked.
    -h, --help              Display this help message.

Example:
    git hotfix -f feat/login-fix -i develop,staging
MSG
        exit 0
    }

    log() {
      echo -e "${CYAN}[INFO]${NC} $1";
    }

    error() {
      echo -e "${RED}[ERROR]${NC} $1";
    }

    rollback() {
        echo -e "\n${YELLOW}Aborted. Rolling back changes...${NC}";
        if [[ -n "$START_BRANCH" ]]; then git checkout "$START_BRANCH" &> /dev/null; fi
        for b in "${CREATED_BRANCHES[@]}"; do
            log "Deleting local branch: $b"
            git branch -D "$b" &> /dev/null
        done
        echo -e "${GREEN}Rollback complete. You are back on ${START_BRANCH}.${NC}"
        exit 1
    }

    get_target_branches() {
        local raw="$1"
        local CLEAN_LIST="${raw//,/ }"
        local result=()

        for branch in $CLEAN_LIST; do
            [[ -z "$branch" ]] && continue

            local exists=0
            for existing in "${result[@]}"; do
                [[ "$existing" == "$branch" ]] && exists=1 && break
            done

            [[ $exists -eq 0 ]] && result+=("$branch")
        done

        echo "${result[@]}"
    }

    parse_args() {
          while [[ "$#" -gt 0 ]]; do
              case "$1" in
                  --from|-f)
                      SOURCE_BRANCH="$2"
                      shift
                      ;;
                  --force)
                      FORCE_PUSH=true
                      ;;
                  --picky|-p)
                      PICKY=true
                      ;;
                  --into|-i)
                      TARGET_BRANCHES_RAW="$2"
                      shift

                      while [[ "$#" -gt 1 && ! "$2" =~ ^- ]]; do
                          TARGET_BRANCHES_RAW="${TARGET_BRANCHES_RAW} $2"
                          shift
                      done
                      ;;
                  -h|--help)
                      show_help
                      ;;
                  *)
                      error "Unknown: $1"
                      show_help
                      ;;
              esac
              shift
          done
    }

    validate_inputs() {

        if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
            error "Not a git repo."
            exit 1
        fi

        SOURCE_BRANCH=${SOURCE_BRANCH:-$(git rev-parse --abbrev-ref HEAD)}

        if [[ -z "$SOURCE_BRANCH" || -z "$TARGET_BRANCHES_RAW" ]]; then
            error "Missing parameters."
            show_help
        fi

        TARGET_BRANCHES=($(get_target_branches "$TARGET_BRANCHES_RAW"))

        if [[ ${#TARGET_BRANCHES[@]} -eq 0 ]]; then
            error "No valid target branches found."
            exit 1
        fi

        if ! git show-ref --verify --quiet "refs/heads/$SOURCE_BRANCH"; then
            if ! git show-ref --verify --quiet "refs/remotes/origin/$SOURCE_BRANCH"; then
                error "Source '$SOURCE_BRANCH' not found."
                exit 1
            fi
        fi
    }

    select_commits() {
        UPSTREAM="origin/${TARGET_BRANCHES[0]}"
        COMMITS_RAW=()
        while IFS= read -r line; do COMMITS_RAW+=("$line"); done < <(git cherry -v "$UPSTREAM" "$SOURCE_BRANCH" | grep '^+' | sed 's/^+ //')

        if [ ${#COMMITS_RAW[@]} -eq 0 ]; then
            error "No unique commits found."; exit 1
        fi

        if [[ "$PICKY" == true ]]; then
            echo -e "\n${YELLOW}--- Select Commits ---${NC}"
            for idx in "${!COMMITS_RAW[@]}"; do printf "%3d) %s\n" $((idx+1)) "${COMMITS_RAW[$idx]}"; done
            echo ""
            read -p "Enter numbers (space separated, oldest first): " SELECTION
            [[ -z "$SELECTION" ]] && { error "None selected."; exit 1; }
            for num in $SELECTION; do
                idx=$((num-1))
                RAW="${COMMITS_RAW[$idx]}"
                SELECTED_COMMITS+=("$(echo "$RAW" | awk '{print $1}')|$(echo "$RAW" | cut -d' ' -f2-)")
            done
        else
            log "Auto-collecting ${#COMMITS_RAW[@]} commits..."
            for line in "${COMMITS_RAW[@]}"; do
                SELECTED_COMMITS+=("$(echo "$line" | awk '{print $1}')|$(echo "$line" | cut -d' ' -f2-)")
            done
        fi
    }

    generate_pr_link() {
        local base=$1; local head=$2
        local remote=$(git remote get-url origin)
        if [[ "$remote" == git@* ]]; then
            remote=${remote//:/\/}; remote=${remote//git@/https:\/\/}
        fi
        remote=${remote%.git}
        echo "$remote/compare/$base...$head?expand=1"
    }

    process_hotfix_targets() {
        # Garante que as variáveis necessárias existam ou recebam valores padrão
        local source_branch="${SOURCE_BRANCH:-}"
        local force_push="${FORCE_PUSH:-}"

        for into in "${TARGET_BRANCHES[@]}"; do
            log "Processing target: $into"

            if ! git checkout "$into" > /dev/null 2>&1; then
                error "Checkout $into failed"; rollback; return 1;
            fi

            if ! git pull origin "$into" --rebase &> /dev/null; then
                error "Pull $into failed"; rollback; return 1;
            fi

            local safe_src="${source_branch//\//-}"
            local hotfix_b="hotfix-${into}-${safe_src}"

            if git show-ref --verify --quiet "refs/heads/$hotfix_b"; then
                git branch -D "$hotfix_b" &> /dev/null
            fi

            if ! git checkout -b "$hotfix_b" &> /dev/null; then
                error "Branch creation failed for $hotfix_b"; rollback; return 1;
            fi

            CREATED_BRANCHES+=("$hotfix_b")

            # Aplicação dos commits (Cherry-pick)
            for item in "${SELECTED_COMMITS[@]}"; do
                local hash msg
                IFS='|' read -r hash msg <<< "$item"

                log "Adding commit $hash"
                if ! git cherry-pick "$hash" > /dev/null 2>&1; then
                    error "Conflict on $hash while targeting $into."
                    git cherry-pick --abort &> /dev/null
                    rollback
                    return 1
                fi
            done

            local push_args="-u origin $hotfix_b"
            [[ "$force_push" == true ]] && push_args="--force $push_args"

            log "Pushing $hotfix_b (Force: $force_push)..."

            if ! git push $push_args &> /dev/null; then
                error "Push failed for $hotfix_b"; rollback; return 1;
            fi

            # Geração do link de PR
            local link
            link=$(generate_pr_link "$into" "$hotfix_b")
            PR_LINKS+=("Target [$into]: $link")
        done
    }

    review_and_confirm() {
        echo -e "\n${YELLOW}--- Review Before Pushing ---${NC}"
        echo -e "Source:    ${GREEN}${SOURCE_BRANCH}${NC}"
        echo -e "Targets:   ${GREEN}${TARGET_BRANCHES[*]}${NC}"
        echo -e "Commits:   ${GREEN}${#SELECTED_COMMITS[@]}${NC}"
        echo "----------------------------"

        read -p "Proceed? (y/yes to confirm): " CONFIRM
        local lower_confirm=$(echo "$CONFIRM" | tr "[:upper:]" "[:lower:]")

        if [[ "$lower_confirm" != "y" && "$lower_confirm" != "yes" ]]; then
            rollback
        fi

        echo -e "\n${GREEN}Confirmed. Processing...${NC}"
    }

    finish_execution() {
        echo -e "\n${GREEN}=== Success ===${NC}"

        if [[ -n "$START_BRANCH" ]]; then
            git checkout "$START_BRANCH" > /dev/null 2>&1
        fi

        for link in "${PR_LINKS[@]}"; do
            echo -e "$link"
        done
  }

    parse_args "$@"
    validate_inputs
    select_commits
    if [[ "$PICKY" == true ]]; then
      review_and_confirm
    fi
    process_hotfix_targets
    finish_execution
EOF
)

ESCAPED_CODE=$(echo "$SCRIPT_CONTENT" | sed "s/'/'\\\\''/g")

git config --global alias.hotfix "!f() {
    bash -c '$ESCAPED_CODE' -- \"\$@\"
}; f"
