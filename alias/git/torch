#!/bin/bash

SCRIPT_CONTENT=$(cat <<'EOF'
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    NC='\033[0m'

    IGNORE_PATTERN="master\|main\|develop"
    SAFE_MODE=false
    FORCE_DEL="-d"

    while [ "$#" -gt 0 ]; do
        case $1 in
            -h|--help)
                cat <<-MSG
    Usage: git torch [options]
    Options:
        -p, --pattern <regex>   Branches to be ignored.
        -s, --safe              Confirm before torching.
        -f, --force             Use -D (force delete).
MSG
                return 0 ;;
            -p|--pattern) IGNORE_PATTERN="$IGNORE_PATTERN\|$2"; shift ;;
            -s|--safe) SAFE_MODE=true ;;
            -f|--force) FORCE_DEL="-D" ;;
            *) echo -e "${RED}Unknown parameter: $1${NC}"; return 1 ;;
        esac
        shift
    done

    MAIN_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
    [ -z "$MAIN_BRANCH" ] && MAIN_BRANCH="main"

    [[ -n $(git status -s) ]] && git stash >/dev/null 2>&1

    BRANCHES_TO_DELETE=$(git branch | grep -v "$IGNORE_PATTERN" | sed 's/^[ *]*//')

    DELETED_COUNT=0
    ERROR_COUNT=0

    if [ -n "$BRANCHES_TO_DELETE" ]; then
        TOTAL_TO_DELETE=$(echo "$BRANCHES_TO_DELETE" | wc -l | xargs)

        if [ "$SAFE_MODE" = true ]; then
            echo -e "${YELLOW}Branches to be torched ($TOTAL_TO_DELETE):${NC}"
            echo "$BRANCHES_TO_DELETE"
            read -p "Confirm? (y/yes to confirm): " CONFIRM < /dev/tty
            LOWER_CONFIRM=$(echo "$CONFIRM" | tr "[:upper:]" "[:lower:]")
            if [[ "$LOWER_CONFIRM" != "y" && "$LOWER_CONFIRM" != "yes" ]]; then
                  echo -e "${RED}Aborted. No branches were torched.${NC}"
                  exit 1
            fi
        fi

        # Deleta uma por uma para capturar erros
        while read -r branch; do
            if git branch $FORCE_DEL "$branch" >/dev/null 2>&1; then
                ((DELETED_COUNT++))
            else
                echo -e "${YELLOW}Skipped: $branch (unmerged or error)${NC}"
                ((ERROR_COUNT++))
            fi
        done <<< "$BRANCHES_TO_DELETE"

        if [ "$DELETED_COUNT" -le 1 ]; then EMOJI="🔥"; elif [ "$DELETED_COUNT" -le 10 ]; then EMOJI="🔥🔥"; else EMOJI="🔥🔥🔥"; fi
    else
        EMOJI="🧊"
    fi

    git checkout "$MAIN_BRANCH" >/dev/null 2>&1
    git fetch origin --prune >/dev/null 2>&1
    git pull origin "$MAIN_BRANCH" >/dev/null 2>&1

    echo -e "\n${RED}Torched $DELETED_COUNT branches $EMOJI${NC}"
    [ "$ERROR_COUNT" -gt 0 ] && echo -e "${YELLOW}Note: $ERROR_COUNT branches could not be deleted (try -f).${NC}"
    echo -e "${GREEN}You are now on $MAIN_BRANCH (updated).${NC}"
EOF
)

ESCAPED_CODE=$(echo "$SCRIPT_CONTENT" | sed "s/'/'\\\\''/g")

git config --global alias.torch "!f() {
    bash -c '$ESCAPED_CODE' -- \"\$@\"
}; f"
