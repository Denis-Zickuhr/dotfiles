#!/bin/bash

SCRIPT_CONTENT=$(cat <<'EOF'
    GREEN="\033[0;32m"; YELLOW="\033[1;33m"; CYAN="\033[0;36m"; RED="\033[0;31m"; NC="\033[0m";

    show_help() {
        cat <<-MSG
Usage: git marry -b <branch-name> [-p <pattern>] [-f]

    -b, --branch <name>     New branch name
    -p, --pattern <path>    File patterns to add (defaults to "src")
    -f, --force             Push without confirmation
    -h, --help              Show help
MSG
    }

    fail() {
        local current_br=$(git rev-parse --abbrev-ref HEAD)
        echo -e "${RED}Error detected. Cleaning up...${NC}"

        git reset --mixed >/dev/null 2>&1
        git checkout "$ORIGINAL_BRANCH" >/dev/null 2>&1

        if [ "$current_br" != "$ORIGINAL_BRANCH" ]; then
            git branch -D "$current_br" >/dev/null 2>&1
        fi

        git stash pop >/dev/null 2>&1
        return 1
    }

    marry() {
        git stash push -u -m "marry_temp_stash" || return 1
        git fresh || return 1
        git checkout -b "$BRANCH_NAME" || return 1

        if ! git stash pop; then
            fail
            return 1
        fi

        for pattern in $ADD_PATTERNS; do
            git add "$pattern"
        done

        if ! git cbn; then
            fail
            return 1
        fi

        local commit_msg=$(git log -1 --pretty=%B)
        local files=$(git diff --name-only HEAD~1)

        if [ "$FORCE_PUSH" = true ]; then
            git push -u origin "$BRANCH_NAME"
        else
            echo -e "\n${YELLOW}--- Review ---${NC}"
            echo -e "Branch: ${GREEN}$BRANCH_NAME${NC}"
            echo -e "Commit: ${GREEN}$commit_msg${NC}"
            echo -e "Files:\n${CYAN}$files${NC}"

            read -p "Push to origin? (y/n): " confirm
            if [[ "$confirm" =~ ^[Yy](es)?$ ]]; then
                git push -u origin "$BRANCH_NAME"
            else
                fail
            fi
        fi
    }

    BRANCH_NAME=""; ADD_PATTERNS=""; FORCE_PUSH=false;
    ORIGINAL_BRANCH=$(git rev-parse --abbrev-ref HEAD)

    while [ "$#" -gt 0 ]; do
        case $1 in
            -h|--help) show_help; return 0;;
            -b|--branch) BRANCH_NAME="$2"; shift;;
            -p|--pattern) ADD_PATTERNS="$ADD_PATTERNS $2"; shift;;
            -f|--force) FORCE_PUSH=true;;
            *) shift;;
        esac
        shift
    done

    [ -z "$BRANCH_NAME" ] && { echo "Branch name required"; return 1; }
    [ -z "$ADD_PATTERNS" ] && ADD_PATTERNS="src"

    marry
EOF
)

ESCAPED_CODE=$(echo "$SCRIPT_CONTENT" | sed "s/'/'\\\\''/g")

git config --global alias.marry "!f() {
    bash -c '$ESCAPED_CODE' -- \"\$@\"
}; f"
