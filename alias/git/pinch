#!/bin/bash

SCRIPT_CONTENT=$(cat <<'EOF'
    editor=$(git config core.editor | sed 's/ --wait//g');

    default_upstream=$(git rev-parse --abbrev-ref origin/HEAD 2>/dev/null | sed "s|origin/||");
    upstream=${default_upstream:-main}

    keep=false;

    while [ $# -gt 0 ]; do
        case "$1" in
            -e|--editor) editor="$2"; shift ;;
            -k|--keep) keep=true ;;
            -u|--upstream) upstream="$2"; shift ;;
            *) break ;;
        esac;
        shift;
    done;

    merge_base=$(git merge-base origin/$upstream HEAD 2>/dev/null);

    if [ -z "$merge_base" ]; then
        echo "Error: Could not find merge base for origin/$upstream.";
        exit 1;
    fi;

    files=$(git diff --name-only $merge_base..HEAD 2>/dev/null | grep -vE "^(vendor/|node_modules/|public/storage/|composer.lock|package-lock.json)");

    if [ -z "$files" ]; then
        echo "No changes detected relative to origin/$upstream.";
        exit 0;
    fi;

    echo "Pinching files changed since diverged from origin/$upstream...";
    echo "$files" | xargs -r -o $editor;

    if [ "$keep" = true ]; then
        git reset --soft $merge_base > /dev/null 2>&1;
        exit 0;
    fi;
EOF
)

ESCAPED_CODE=$(echo "$SCRIPT_CONTENT" | sed "s/'/'\\\\''/g")

git config --global alias.pinch "!f() {
    bash -c '$ESCAPED_CODE' -- \"\$@\"
}; f"
